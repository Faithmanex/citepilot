# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgres://citepilot:citepilot@localhost:5432/citepilot

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=86400

# AI Service
AI_SERVICE_URL=http://localhost:8000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# S3 (optional for MVP — uses local filesystem when not set)
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=citepilot-documents
